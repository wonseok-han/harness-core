{
  "domain": "AI SDLC Harness",
  "terms": {
    "harness": {
      "definition": "AI 에이전트의 SDLC 행동을 제어하는 프레임워크 전체를 지칭",
      "aliases": [
        "framework",
        "core"
      ],
      "context": "package name, CLI commands"
    },
    "adapter": {
      "definition": "AI 에이전트별 설정 파일 생성기. 공유 로직을 에이전트 고유 형식으로 변환",
      "aliases": [
        "agent adapter"
      ],
      "context": "src/engines/adapters/"
    },
    "guardrail": {
      "definition": "아키텍처 규칙, import 제한, scope 제한 등 AI가 지켜야 할 자동 강제 규칙",
      "aliases": [
        "guard",
        "policy",
        "rule"
      ],
      "context": "src/engines/policy/"
    },
    "transpiler": {
      "definition": "raw 에러 로그를 AI가 읽을 수 있는 구조화된 마크다운+JSON으로 변환하는 엔진",
      "aliases": [
        "log transpiler"
      ],
      "context": "src/engines/log-transpiler/"
    },
    "scaffolder": {
      "definition": "component, hook, util, service, model, test 6종 파일을 표준 구조로 자동 생성하는 도구",
      "aliases": [
        "generator"
      ],
      "context": "src/engines/agent-tools/scaffolder.ts"
    },
    "scope-guard": {
      "definition": "AI 에이전트가 허용된 디렉토리 밖의 파일을 수정하지 못하게 차단하는 보호 장치",
      "context": "src/engines/agent-tools/scope-guard.ts"
    },
    "self-healing": {
      "definition": "테스트 실패 시 에러 리포트를 AI에게 피드백하여 자동 재시도하는 루프",
      "aliases": [
        "healing loop"
      ],
      "context": "src/cli/commands/test.ts"
    },
    "forbidden-imports": {
      "definition": "아키텍처 스타일에 따라 특정 모듈 간 import를 금지하는 규칙",
      "aliases": [
        "import restriction"
      ],
      "context": "src/engines/policy/import-checker.ts"
    },
    "domain-glossary": {
      "definition": "프로젝트 도메인 용어를 정의한 JSON 파일",
      "context": "domain-glossary.json"
    },
    "feature-spec": {
      "definition": "기능별 기획 의도, 인풋/아웃풋, 예외 케이스를 정의한 마크다운 문서",
      "context": "docs/features/*.md"
    },
    "auto-discovery": {
      "definition": "package.json, lock 파일 등을 스캔하여 프로젝트 환경을 자동 감지하는 엔진",
      "context": "src/engines/discovery/"
    },
    "hook-orchestrator": {
      "definition": "Husky + Claude Code hooks를 자동 생성하는 엔진",
      "aliases": [
        "hook generator"
      ],
      "context": "src/engines/policy/hooks/"
    }
  },
  "features": [
    {
      "feature": "project-initialization",
      "intent": "단일 명령어로 프레임워크 scaffolding부터 AI 에이전트 통합까지 완료하는 원스톱 프로젝트 생성",
      "input": {
        "description": "사용자 선택 항목",
        "fields": {
          "name": {
            "type": "string",
            "required": false,
            "description": "프로젝트 이름"
          },
          "framework": {
            "type": "Framework",
            "required": true,
            "description": "웹 프레임워크"
          },
          "adapters": {
            "type": "AgentType[]",
            "required": true,
            "description": "AI 에이전트 목록"
          }
        }
      },
      "output": {
        "description": "완전한 프로젝트 디렉토리",
        "fields": {
          "projectDir": {
            "type": "string",
            "required": true,
            "description": "생성된 프로젝트 경로"
          }
        }
      },
      "exceptions": [
        {
          "condition": "동명 디렉토리 존재",
          "behavior": "사용자에게 확인",
          "errorCode": "DIR_EXISTS"
        },
        {
          "condition": "프레임워크 CLI 실패",
          "behavior": "minimal project 폴백",
          "errorCode": "SCAFFOLD_FAIL"
        }
      ]
    },
    {
      "feature": "agent-adapter-system",
      "intent": "다양한 AI 에이전트에 대해 각자의 규칙 파일 형식으로 guardrail을 주입하는 확장 가능한 어댑터 시스템",
      "input": {
        "description": "harness 설정",
        "fields": {
          "config": {
            "type": "HarnessConfig",
            "required": true,
            "description": "설정 내용"
          },
          "adapterType": {
            "type": "AgentType",
            "required": true,
            "description": "대상 AI 에이전트"
          }
        }
      },
      "output": {
        "description": "에이전트별 설정 파일",
        "fields": {
          "files": {
            "type": "Record<string,string>",
            "required": true,
            "description": "생성된 파일 맵"
          }
        }
      },
      "exceptions": [
        {
          "condition": "미지원 에이전트",
          "behavior": "generic 어댑터 폴백",
          "errorCode": "UNKNOWN_AGENT"
        }
      ]
    },
    {
      "feature": "domain-analysis",
      "intent": "도메인 용어와 기능 스펙을 정의하여 AI가 프로젝트 맥락을 정확히 이해할 수 있게 하는 분석 단계",
      "input": {
        "description": "분석 입력",
        "fields": {
          "scanMode": {
            "type": "boolean",
            "required": false,
            "description": "프로젝트 정적 분석 모드"
          },
          "fromFile": {
            "type": "string",
            "required": false,
            "description": "사전 작성 JSON 파일 경로"
          }
        }
      },
      "output": {
        "description": "분석 산출물",
        "fields": {
          "glossary": {
            "type": "DomainGlossary",
            "required": true,
            "description": "domain-glossary.json"
          }
        }
      },
      "exceptions": [
        {
          "condition": "JSON 파싱 실패",
          "behavior": "에러 출력 후 종료",
          "errorCode": "INVALID_JSON"
        }
      ]
    },
    {
      "feature": "architecture-sync",
      "intent": "config 변경 시 모든 AI 에이전트 설정과 git hooks를 자동 재생성하여 동기화 보장",
      "input": {
        "description": "sync 옵션",
        "fields": {
          "root": {
            "type": "string",
            "required": true,
            "description": "프로젝트 루트"
          },
          "watch": {
            "type": "boolean",
            "required": false,
            "description": "파일 변경 감시 모드"
          }
        }
      },
      "output": {
        "description": "동기화 결과",
        "fields": {
          "violations": {
            "type": "ImportViolation[]",
            "required": true,
            "description": "import 위반 목록"
          }
        }
      },
      "exceptions": [
        {
          "condition": "config 없음",
          "behavior": "harness init 안내",
          "errorCode": "NO_CONFIG"
        }
      ]
    },
    {
      "feature": "test-self-healing",
      "intent": "테스트 실패 시 Log Transpiler로 에러를 구조화하고 최대 3회 자동 재시도하는 자가 치유 루프",
      "input": {
        "description": "테스트 설정",
        "fields": {
          "root": {
            "type": "string",
            "required": true,
            "description": "프로젝트 루트"
          }
        }
      },
      "output": {
        "description": "테스트 결과",
        "fields": {
          "passed": {
            "type": "boolean",
            "required": true,
            "description": "최종 통과 여부"
          },
          "report": {
            "type": "TranspiledReport",
            "required": true,
            "description": "에러 리포트"
          }
        }
      },
      "exceptions": [
        {
          "condition": "최대 재시도 초과",
          "behavior": "리포트 저장 후 실패 종료",
          "errorCode": "HEAL_MAX_RETRY"
        }
      ]
    }
  ]
}