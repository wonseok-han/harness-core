{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analysis Specification",
  "type": "object",
  "required": [
    "feature",
    "intent",
    "input",
    "output",
    "exceptions"
  ],
  "properties": {
    "feature": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 10
    },
    "input": {
      "type": "object",
      "required": [
        "description",
        "fields"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "type": "object"
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "description",
        "fields"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "type": "object"
        }
      }
    },
    "exceptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "condition",
          "behavior"
        ],
        "properties": {
          "condition": {
            "type": "string"
          },
          "behavior": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          }
        }
      }
    }
  }
}
